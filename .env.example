# URL canonique du site (obligatoire en production — Hostinger)
NEXT_PUBLIC_SITE_URL=https://smartrenov237.com

# Cloudflare Turnstile — formulaire contact
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# E-mail formulaire contact — choisir UNE des deux options ci-dessous
#
# Option A — Resend (https://resend.com) : clé API + domaine vérifié
RESEND_API_KEY=
CONTACT_EMAIL_FROM=Smart Rénov <contact@smartrenov237.com>
CONTACT_EMAIL_TO=contact@smartrenov237.com
#
# Option B — SMTP Hostinger (boîte mail existante contact@smartrenov237.com)
# Si RESEND_API_KEY est vide, SMTP est utilisé automatiquement.
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=contact@smartrenov237.com
# SMTP_PASS=mot_de_passe_de_la_boite_mail

# Google Search Console — https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools (Google Edge, Brave utilisent aussi Bing) — https://www.bing.com/webmasters
NEXT_PUBLIC_BING_SITE_VERIFICATION=
